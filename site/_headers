# Game logic, markup, and translations change often — never serve a stale copy.
# The <meta> Cache-Control tags in index.html are ignored by browsers/edges for
# the document navigation itself, so a stale index.html can hide new code (e.g.
# an old cover instead of the new splash). Pin no-cache at the edge for the whole
# game folder — HTML included — and for the landing page.
/play/*
  Cache-Control: no-cache, must-revalidate
/
  Cache-Control: no-cache, must-revalidate
/index.html
  Cache-Control: no-cache, must-revalidate
